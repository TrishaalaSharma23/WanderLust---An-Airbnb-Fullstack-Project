<%- layout("./layouts/boilerplate.ejs") %>

<body>
    <div class="row">
        <div class="col-6 offset-3">
            <h3>EDIT FORM</h3>
            <form enctype="multipart/form-data" needs-validation method="POST" action="/listings/<%= list._id %>?_method=PUT" novalidate>
                    <div class="mb-4">
                        <label for="title" class="form-label">Title</label>
                        <input required type="text" name="listing[title]" placeholder="Enter title" class="form-control"
                            value="<%= list.title %>">
                        <div class="invalid-feedback">Title is required.</div>
                    </div>
                    <div class="mb-4">
                        <label for="description" class="form-label">Description</label>
                        <textarea required class="form-control" name="listing[description]" id="desc"
                            placeholder="Enter description"><%= list.title %></textarea>
                        <div class="invalid-feedback">Description is required.</div>
                    </div>

                    <div class="mb-4">
                        Original Listing image : <br>
                        <img src="<%= originalImageUrl %>" alt="">
                    </div>

                    <div class="mb-4">
                        <label for="image" class="form-label">New Listing Image:</label>
                        <input class="form-control" type="file" name="listing[image]" />
                        <div class="invalid-feedback">Image is required.</div>
                    </div>
                    <div class="row">
                        <div class="mb-4 col-lg-8 col-md-8 col-sm-12">
                            <label for="location" class="form-label">Location</label>
                            <input required class="form-control" type="text" name="listing[location]" placeholder="Jaipur"
                                value="<%= list.location %>">
                            <div class="invalid-feedback">Location is required.</div>
                        </div>
                        <div class="mb-4 col-lg-4 col-md-4 col-sm-12">
                            <label for="country" class="form-label">Country</label>
                            <input required class="form-control" value="<%= list.country %>" type="text" name="listing[country]"
                                placeholder="Rajasthan">
                            <div class="invalid-feedback">Country is required.</div>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label for="price" class="form-label">Price</label>
                        <input required type="text" class="form-control" name="listing[price]" placeholder="Enter price"
                            value="<%= list.price %>">
                        <div class="invalid-feedback">Price is required.</div>
                    </div>
                    <button class="btn btn-dark mb-4 edit-btn" type="submit">EDIT</button>
                </form>
            </div>
        </div>
    </body>