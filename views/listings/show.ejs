<%- layout("./layouts/boilerplate.ejs") %>

    <div class="row offset-3 show-container mb-3">
        <div class="col-8 show-page my-2">
            <h3 class="my-2">
                <%= listing.title %>
            </h3>

            <div class="card">
                <img style="height: 25rem !important;" src="<%= listing.image.url %>" class="card-img-top"
                    alt="listing_image">
                <div class="card-body">
                    <i>Owned By: <%= listing.owner.username %></i> <br>
                    <%= listing.description %> <br>
                        &#8377; <%= listing.price.toLocaleString("en-IN") %> / night <br>
                            <%= listing.location %> <br>
                                <%= listing.country %>
                </div>
            </div>

            <% if (currUser && currUser._id.equals(listing.owner._id)) { %>
                <div id="btns" class="btns offset-4 m-3">
                    <a class="btn btn-dark edit-btn mx-4" href="/listings/<%= listing._id %>/edit">EDIT</a> <br>
                    <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                        <button class="btn btn-dark" type="submit">DELETE</button>
                    </form>
                </div>
                <% } %>
        </div>
        <div class="col-8 my-3">
            <% if(currUser) { %>
                <hr />
                <h4>Leave a Review</h4>
                <form class="needs-validation" novalidate method="POST" action="/listings/<%= listing._id %>/reviews">
                    <label for="rating" class="form-label">Rating</label>
                    <fieldset class="starability-slot">
                        <input type="radio" id="no-rate" class="input-no-rate" name="review[ratings]" value="1" checked
                            aria-label="No rating." />
                        <input type="radio" id="first-rate1" name="review[ratings]" value="1" />
                        <label for="first-rate1" title="Terrible">1 star</label>
                        <input type="radio" id="first-rate2" name="review[ratings]" value="2" />
                        <label for="first-rate2" title="Not good">2 stars</label>
                        <input type="radio" id="first-rate3" name="review[ratings]" value="3" />
                        <label for="first-rate3" title="Average">3 stars</label>
                        <input type="radio" id="first-rate4" name="review[ratings]" value="4" />
                        <label for="first-rate4" title="Very good">4 stars</label>
                        <input type="radio" id="first-rate5" name="review[ratings]" value="5" />
                        <label for="first-rate5" title="Amazing">5 stars</label>
                    </fieldset>
                    <div>
                        <label class="form-label" for="comment">Comment</label>
                        <textarea required class="form-control" name="review[comment]" id="comment"
                            placeholder="Write your review here."></textarea>
                        <div class="invalid-feedback">Valid Review is required.</div>
                    </div>
                    <button class="edit-btn my-3 p-1 px-2" type="submit">SUBMIT</button>
                </form>
                <% } %>
        </div>
        <% if(listing.reviews.length>0) { %>
            <div class="col-8 my-1">
                <h4>All Reviews</h4>
                <div class="row">
                    <% for(review of listing.reviews) { %>
                        <div class="card review-card col-5 m-2 ms-3">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <%= review.author.username %>
                                </h5>
                                <p class="starability-result card-text" data-rating="<%= review.ratings %>"></p>
                                <div>
                                    <p class="card-text">
                                        <%= review.comment %>
                                    </p>
                                </div>
                            </div>
                            <form class="mx-3" method="POST"
                                action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                <button class="btn btn-sm btn-dark del-btn p-1 mb-2">DELETE</button>
                            </form>
                        </div>
                        <% } %>
                </div>
            </div>

            <% } %>

                <!-- <div class="col-8 show-page my-2">
                    <hr />
                    <h3>Where you'll be</h3>
                    <div id="map"></div>
                </div> -->
    </div>

    <!-- <script src="/js/map.js"></script> -->