<%- layout("./layouts/boilerplate.ejs") %>

    <div style="margin-bottom:11.5rem !important;" class="row mt-3">
        <h1 class="col-6 offset-3">SignUp on WanderLust</h1>
        <div class="col-6 offset-3">
            <form class="needs-validation" novalidate action="/signup" method="POST">
                
                <div class="mb-4">
                    <label for="username" class="form-label">Username</label>
                    <input id="username" name="username" required type="text" class="form-control">
                    <div class="invalid-feedback">Username is required.</div>
                </div>

                <div class="mb-4">
                    <label for="email" class="form-label">Email</label>
                    <input id="email" name="email" required type="email" class="form-control">
                </div>

                <div class="mb-4">
                    <label for="password" class="form-label">Password</label>
                    <input id="password" name="password" required type="password" class="form-control">
                </div>

                <button class="btn btn-success" type="submit">SignUp</button>
            </form>
        </div>
    </div>